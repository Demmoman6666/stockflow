# Copy this file to .env.local and fill in your real values
# NEVER commit .env.local to git

# ── Shopify Store 1 ──────────────────────────────────────
SHOPIFY_STORE1_DOMAIN=yourstore1.myshopify.com
SHOPIFY_STORE1_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx

# ── Shopify Store 2 ──────────────────────────────────────
SHOPIFY_STORE2_DOMAIN=yourstore2.myshopify.com
SHOPIFY_STORE2_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx

# ── Linnworks ─────────────────────────────────────────────
LINNWORKS_APP_ID=your_app_id
LINNWORKS_APP_SECRET=your_app_secret
LINNWORKS_TOKEN=your_session_token

# ── App ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=StockFlow
